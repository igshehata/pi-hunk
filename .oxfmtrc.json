{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "proseWrap": "always",
  "singleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    ".pi-subagents/**",
    "package-lock.json"
  ]
}
